# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# Google Maps API key for Android native map tiles (react-native-maps).
# Create a key at https://console.cloud.google.com/ and restrict it to
# the "Maps SDK for Android" API and your app's package name / SHA-1.
GOOGLE_MAPS_ANDROID_API_KEY=

# (Optional) Google Maps Static API key used for server-side/web static map images.
# Can be the same key as above if it also has the "Maps Static API" enabled.
EXPO_PUBLIC_GOOGLE_MAPS_STATIC_KEY=
