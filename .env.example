# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# ── Maps ──────────────────────────────────────────────────────────────────────

# Google Maps API key for Android native map tiles (react-native-maps).
# Create a key at https://console.cloud.google.com/ and restrict it to
# the "Maps SDK for Android" API and your app's package name / SHA-1.
GOOGLE_MAPS_ANDROID_API_KEY=

# (Optional) Google Maps Static API key used for server-side/web static map images.
# Can be the same key as above if it also has the "Maps Static API" enabled.
EXPO_PUBLIC_GOOGLE_MAPS_STATIC_KEY=

# ── API endpoint overrides ─────────────────────────────────────────────────────
# Leave these empty to use the default public OSS endpoints (no account needed).
# Override to point at a self-hosted or staging mirror, e.g. for CI/testing.

# Comma-separated list of Overpass API mirrors (tried in order).
# Default: overpass-api.de, overpass.kumi.systems, maps.mail.ru
OVERPASS_ENDPOINTS=

# Nominatim reverse-geocoding base URL (without path).
# Default: https://nominatim.openstreetmap.org
NOMINATIM_BASE_URL=

# Open-Meteo forecast API base URL.
# Default: https://api.open-meteo.com
OPEN_METEO_BASE_URL=

# ── Feature flags ──────────────────────────────────────────────────────────────
# Set to "false" or "0" to disable the corresponding tab at build time.
# Useful for white-label builds or deployments where certain tabs must be hidden.

FEATURE_EMERGENCY_TAB=true
FEATURE_TRIPLOGGER_TAB=true
FEATURE_MC_TAB=true

# ── Crash reporting ────────────────────────────────────────────────────────────
# Sentry Data Source Name (DSN).  Leave empty to disable crash reporting.
# Requires @sentry/react-native — see SIGNING.md for setup instructions.
SENTRY_DSN=
